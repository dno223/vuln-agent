# SeptZen Site Vulnerability Watcher — .env
# Copy to .env and fill in values

# NVD API Key (get free at https://nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=your_nvd_api_key_here

# SMTP — Gmail example (use App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# Where to send vulnerability alerts
ALERT_TO_EMAIL=daniel@septzen.com
ALERT_FROM_NAME=SeptZen Vuln Watcher

# Scan settings
VULN_DAYS_BACK=7       # How many days back to scan NVD
MIN_CVSS_SCORE=5.0     # Ignore CVEs below this score (0-10)
